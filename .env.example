# Flask
FLASK_DEBUG=1
SECRET_KEY=change-me

# MyMemory — translation (no key required; optional email for higher limits)
MYMEMORY_URL=https://api.mymemory.translated.net/get
MYMEMORY_EMAIL=

# Glosbe — bilingual example sentences (no key)
GLOSBE_URL=https://glosbe.com/gapi/v0.1/translate
GLOSBE_USER_AGENT=EstudioPersonal/1.0 (student project)

# DictionaryAPI.dev — English definitions (no key)
DICTIONARY_API_BASE=https://api.dictionaryapi.dev/api/v2/entries/en

# Open Trivia DB — quiz questions (no key)
OPENTDB_API_URL=https://opentdb.com/api.php

# Scheduler
SCHEDULER_ENABLED=true
REFRESH_INTERVAL_MINUTES=15
