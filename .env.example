# Flask
FLASK_DEBUG=1
SECRET_KEY=change-me

# Encryption — user data at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# MyMemory — translation (Google backend; cached in cache.json)
# Set MYMEMORY_EMAIL on Render to raise shared-server quota (5k → 50k chars/day).
MYMEMORY_URL=https://api.mymemory.translated.net/get
MYMEMORY_EMAIL=
# Comma-separated Lingva instances; first success wins (parallel race).
LINGVA_URLS=https://lingva.ml/api/v1
# Optional LibreTranslate fallback (requires a working instance + key; leave empty by default).
LIBRETRANSLATE_URL=

# DictionaryAPI.dev — English definitions (no key)
DICTIONARY_API_BASE=https://api.dictionaryapi.dev/api/v2/entries/en

# Scheduler — background cache refresh (no manual /refresh route)
SCHEDULER_ENABLED=true
REFRESH_INTERVAL_MINUTES=15

# NewsAPI — Spanish headlines about Spain (server-side only; get key at newsapi.org)
NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2/everything

# Google Maps JavaScript API — embedded travel map + walking routes (console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# Google Places API — optional; enhances travel recommendations (get key at console.cloud.google.com)
GOOGLE_PLACES_API_KEY=

# Require login for /translate/api and /voice/translate in production (FLASK_DEBUG=0)
TRANSLATION_REQUIRES_AUTH=0

