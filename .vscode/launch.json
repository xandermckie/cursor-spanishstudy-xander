{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Estudio Abroad (reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}",
      "env": {
        "FLASK_APP": "app:app",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "run",
        "--host",
        "127.0.0.1",
        "--port",
        "5000",
        "--debug",
        "--no-debugger"
      ],
      "jinja": true,
      "autoStartBrowser": true,
      "justMyCode": true
    },
    {
      "name": "Flask: no reload (stable breakpoints)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}",
      "env": {
        "FLASK_APP": "app:app",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "run",
        "--host",
        "127.0.0.1",
        "--port",
        "5000",
        "--debug",
        "--no-debugger",
        "--no-reload"
      ],
      "jinja": true,
      "autoStartBrowser": true,
      "justMyCode": true
    }
  ]
}
